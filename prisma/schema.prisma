generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model RecipeUrl {
  id          Int           @id @default(autoincrement())
  recipeUrl   String        @unique @map("recipe_url")
  recipeDate  DateTime?     @map("recipe_date")
  htmlContent String?       @map("html_content") @db.LongText
  images      RecipeImage[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("recipe_urls")
}

model RecipeImage {
  id           Int       @id @default(autoincrement())
  recipeUrl    RecipeUrl @relation(fields: [recipeUrlId], references: [id])
  recipeUrlId  Int       @map("recipe_url_id")
  imageUrl     String    @map("image_url") @db.Text
  imageUrlHash String    @map("image_url_hash") @db.Char(32)
  altText      String?   @map("alt_text")
  valid        Boolean   @default(true) @map("valid")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([recipeUrlId, imageUrlHash])
  @@map("recipe_images")
}
