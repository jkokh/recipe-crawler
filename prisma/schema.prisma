generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model RecipeUrl {
  id          Int           @id @default(autoincrement())
  recipeUrl   String        @unique @map("recipe_url")
  recipeDate  DateTime?     @map("recipe_date")
  htmlContent String?       @map("html_content") @db.LongText
  htmlClean   String?       @map("html_clean") @db.LongText
  json        String?       @map("json") @db.LongText
  images      RecipeImage[]
  fail        Boolean       @default(false)

  recipeId Int?    @unique @map("recipe_id") // ensure 1-to-1 if needed
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@map("recipe_urls")
}

model RecipeImage {
  id                  Int                   @id @default(autoincrement())
  recipeUrlId         Int                   @map("recipe_url_id")
  imageUrl            String                @map("image_url") @db.Text
  altText             String?               @map("alt_text") @db.VarChar(1024)
  valid               Boolean               @default(true) @map("valid")
  type                String?               @map("type")
  recipeUrl           RecipeUrl             @relation(fields: [recipeUrlId], references: [id])
  RecipeStepImageLink RecipeStepImageLink[]

  @@index([recipeUrlId], map: "idx_recipe_images_recipe_url_id")
  @@map("recipe_images")
}

model Language {
  code  String @id @db.VarChar(8)
  title String @db.VarChar(64)

  @@map("language")
}

model Ingredient {
  id                Int                     @id @default(autoincrement())
  canonicalName     String                  @unique @map("canonical_name") @db.VarChar(255)
  name              String
  translations      IngredientTranslation[]
  recipeIngredients RecipeIngredient[]

  @@map("ingredient")
}

model IngredientTranslation {
  id           Int        @id @default(autoincrement())
  ingredientId Int        @map("ingredient_id")
  languageCode String     @map("language_code") @db.VarChar(8)
  name         String     @db.VarChar(255)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([ingredientId, languageCode])
  @@map("ingredient_translation")
}

model RecipeIngredient {
  id           Int                           @id @default(autoincrement())
  recipeId     Int                           @map("recipe_id")
  ingredientId Int?                          @map("ingredient_id")
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt
  text         String                        @db.VarChar(255)
  ingredient   Ingredient?                   @relation(fields: [ingredientId], references: [id])
  recipe       Recipe                        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  translations RecipeIngredientTranslation[]

  @@index([ingredientId], map: "recipe_ingredient_ingredient_id_fkey")
  @@index([recipeId], map: "recipe_ingredient_recipe_id_fkey")
  @@map("recipe_ingredient")
}

model RecipeIngredientTranslation {
  id                 Int              @id @default(autoincrement())
  recipeIngredientId Int              @map("recipe_ingredient_id")
  languageCode       String           @db.VarChar(8)
  translatedText     String           @db.VarChar(255)
  recipeIngredient   RecipeIngredient @relation(fields: [recipeIngredientId], references: [id], onDelete: Cascade)

  @@unique([recipeIngredientId, languageCode])
  @@map("recipe_ingredient_translation")
}

model RecipeStep {
  id           Int                     @id @default(autoincrement())
  recipeId     Int                     @map("recipe_id")
  order        Int                     @default(0)
  text         String                  @db.Text
  recipe       Recipe                  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  images       RecipeStepImageLink[]
  translations RecipeStepTranslation[]

  @@index([recipeId], map: "recipe_step_recipe_id_fkey")
  @@map("recipe_step")
}

model RecipeStepTranslation {
  id             Int        @id @default(autoincrement())
  recipeStepId   Int        @map("recipe_step_id")
  languageCode   String     @db.VarChar(8)
  translatedText String     @db.Text
  recipeStep     RecipeStep @relation(fields: [recipeStepId], references: [id], onDelete: Cascade)

  @@unique([recipeStepId, languageCode])
  @@map("recipe_step_translation")
}

model RecipeStepImageLink {
  id            Int         @id @default(autoincrement())
  recipeStepId  Int         @map("recipe_step_id")
  recipeImageId Int         @map("recipe_image_id")
  recipeImage   RecipeImage @relation(fields: [recipeImageId], references: [id], onDelete: Cascade)
  recipeStep    RecipeStep  @relation(fields: [recipeStepId], references: [id], onDelete: Cascade)

  @@unique([recipeStepId, recipeImageId])
  @@index([recipeImageId], map: "recipe_step_image_link_recipe_image_id_fkey")
  @@map("recipe_step_image_link")
}

model Recipe {
  id             Int                 @id @default(autoincrement())
  slug           String              @unique @db.VarChar(255)
  title          String              @db.VarChar(255)
  description    String?             @db.LongText
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  seo            String?             @db.VarChar(255)
  nutritions     Nutrition[]
  ingredients    RecipeIngredient[]
  steps          RecipeStep[]
  tags           RecipeTagLink[]
  translations   RecipeTranslation[]
  RecipeUrl      RecipeUrl[]
  RecipeCategory RecipeCategory[]

  @@map("recipe")
}

model RecipeTranslation {
  id           Int     @id @default(autoincrement())
  recipeId     Int     @map("recipe_id")
  languageCode String  @db.VarChar(8)
  title        String  @db.VarChar(255)
  description  String? @db.Text
  recipe       Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, languageCode])
  @@map("recipe_translation")
}

model Nutrition {
  id           Int                    @id @default(autoincrement())
  text         String                 @db.VarChar(255)
  recipeId     Int                    @map("recipe_id")
  recipe       Recipe                 @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  translations NutritionTranslation[]

  @@index([recipeId])
  @@map("nutrition")
}

model NutritionTranslation {
  id           Int       @id @default(autoincrement())
  nutritionId  Int       @map("nutrition_id")
  languageCode String    @map("language_code") @db.VarChar(8)
  text         String    @db.VarChar(255)
  nutrition    Nutrition @relation(fields: [nutritionId], references: [id], onDelete: Cascade)

  @@unique([nutritionId, languageCode])
  @@index([languageCode])
  @@map("nutrition_translation")
}

model Tag {
  id           Int              @id @default(autoincrement())
  name         String           @db.VarChar(255)
  createdAt    DateTime         @default(now()) @map("created_at")
  slug         String           @unique @map("slug") @db.VarChar(255)
  recipes      RecipeTagLink[]
  translations TagTranslation[]

  @@map("tag")
}

model TagTranslation {
  id           Int    @id @default(autoincrement())
  tagId        Int    @map("tag_id")
  languageCode String @map("language_code") @db.VarChar(8)
  name         String @db.VarChar(255)
  tag          Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, languageCode])
  @@map("tag_translation")
}

model RecipeTagLink {
  recipeId Int
  tagId    Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recipeId, tagId])
  @@index([tagId], map: "recipe_tag_link_tagId_fkey")
  @@map("recipe_tag_link")
}

model Category {
  id       Int        @id @default(autoincrement())
  parentId Int?
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryChildren")

  title String
  slug  String

  // Relations
  recipes RecipeCategory[]

  // Meta
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentId, slug])
  @@index([parentId])
  @@index([slug])
}

model RecipeCategory {
  recipeId   Int
  categoryId Int

  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  slug        String
  description String?  @db.Text

  createdAt DateTime @default(now())

  @@id([recipeId, categoryId])
  @@index([categoryId, recipeId])
}
